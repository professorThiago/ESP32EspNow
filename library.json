{
  "name": "ESP32EspNow",
  "version": "1.0.0",
  "description": "Gerenciamento completo de ESP-NOW para ESP32: descoberta automatica de modulos, registro de peers com NVS, envio e recepcao de mensagens tipadas. Projetado para sistemas multi-modulo com um dispositivo central.",
  "keywords": [
    "ESP-NOW", "ESP32", "descoberta", "peers", "NVS",
    "automacao", "sem-fio", "IoT", "sala de aula"
  ],
  "authors": [
    {
      "name": "professorThiago",
      "url": "https://github.com/professorThiago"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/professorThiago/ESP32EspNow"
  },
  "license": "MIT",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "headers": "ESP32EspNow.h",
  "build": { "srcDir": "src" },
  "examples": [
    {
      "name": "DescobertaModulos",
      "base": "examples/DescobertaModulos",
      "files": ["DescobertaModulos.ino"]
    },
    {
      "name": "SistemaCompleto",
      "base": "examples/SistemaCompleto",
      "files": ["SistemaCompleto.ino"]
    }
  ]
}
